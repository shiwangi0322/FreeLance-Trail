// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ClientStatus {
  ACTIVE
  INACTIVE
}

enum ProjectStatus {
  PLANNED
  IN_PROGRESS
  ON_HOLD
  COMPLETED
}

enum InvoiceStatus {
  DRAFT
  PENDING
  PAID
  OVERDUE
}

enum ProposalStatus {
  DRAFT
  SENT
  ACCEPTED
  DECLINED
}

enum DocumentFolder {
  PROPOSALS
  CONTRACTS
  INVOICES
  DESIGN
  OTHER
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         String   @default("Owner")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  clients   Client[]
  projects  Project[]

  @@map("users")
}

model Client {
  id          String       @id @default(cuid())
  userId      String
  name        String
  email       String?
  status      ClientStatus @default(ACTIVE)
  avatarColor String       @default("#8B5CF6")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects Project[]

  @@index([userId])
  @@map("clients")
}

model Project {
  id        String        @id @default(cuid())
  userId    String
  clientId  String
  title     String
  status    ProjectStatus @default(PLANNED)
  startDate DateTime?
  endDate   DateTime?
  budget    Decimal       @default(0) @db.Decimal(12, 2)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  client    Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  documents Document[]
  invoices  Invoice[]
  proposals Proposal[]

  @@index([userId])
  @@index([clientId])
  @@map("projects")
}

model Invoice {
  id         String        @id @default(cuid())
  projectId  String
  number     String        @unique
  status     InvoiceStatus @default(DRAFT)
  issueDate  DateTime      @default(now())
  dueDate    DateTime?
  taxRate    Decimal       @default(18) @db.Decimal(5, 2)
  amountPaid Decimal       @default(0) @db.Decimal(12, 2)
  notes      String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  project Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  items   InvoiceItem[]

  @@index([projectId])
  @@map("invoices")
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  name        String
  description String?
  qty         Decimal  @default(1) @db.Decimal(10, 2)
  rate        Decimal  @default(0) @db.Decimal(12, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_items")
}

model Proposal {
  id            String         @id @default(cuid())
  projectId     String
  timelineWeeks Int            @default(4)
  budget        Decimal        @default(0) @db.Decimal(12, 2)
  deliverables  String[]       @default([])
  status        ProposalStatus @default(DRAFT)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("proposals")
}

model Document {
  id         String         @id @default(cuid())
  projectId  String
  name       String
  folder     DocumentFolder @default(OTHER)
  sizeMB     Decimal        @default(0) @db.Decimal(10, 2)
  fileUrl    String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("documents")
}